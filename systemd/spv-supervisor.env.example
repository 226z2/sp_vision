# Host-side supervisor defaults.
# Copy to /etc/default/spv-supervisor and adjust as needed.

SPV_ROOT_DIR=/home/gzu-printk/sp_vision/sp_vision_25-main-main
IMAGE_NAME=sp_vision_25
TAG=dev_5
SPV_SUPERVISOR_CONTAINER_NAME=spv_supervised_app

USE_HOST_NET=no
FORWARD_PORTS=8877 8878 8765
ENABLE_GPU=0
GIMBAL_DEV_CONT=/dev/gimbal

SPV_BUILD_DIR=build
SPV_RUN_TARGET=auto_aim_test
SPV_RUN_ARGS=--source=camera --config-path=configs/sentry.yaml --dm-send=true --allow-shoot=false --bullet-speed=27

SPV_AUTOSTART=1
SPV_SUPERVISE=1
SPV_REQUIRED_CAMERA=1
SPV_REQUIRED_SERIAL=1
SPV_SERIAL_CANDIDATES=/dev/gimbal,/dev/ttyACM0,/dev/ttyACM1,/dev/ttyACM2,/dev/ttyUSB0,/dev/ttyUSB1,/dev/ttyUSB2
SPV_SERIAL_BAUD=115200
SPV_RESTART_DELAY_MS=1500
SPV_STARTUP_TIMEOUT_SEC=0

SPV_FOXGLOVE_PORT=8765
SPV_WS_ENABLE=1
SPV_WS_PORT=8878
SPV_WS_BIND_HOST=0.0.0.0

SPV_FAIL_NOTIFY_ENABLE=1
SPV_FAIL_NOTIFY_HOST=127.0.0.1
SPV_FAIL_NOTIFY_PORT=18878
SPV_FAIL_NOTIFY_SERVICE_NAME=spv_supervisor
